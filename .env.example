# ── Database (Neon Postgres) ───────────────────────────────────────────────
# Pooled connection string from the Neon dashboard.
DATABASE_URL=

# ── Clerk (manager authentication) ─────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Upstash QStash (recurring schedules + delayed close jobs) ───────────────
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── App ─────────────────────────────────────────────────────────────────────
# Publicly reachable base URL used as the QStash destination + public links.
# Locally use a tunnel (ngrok/cloudflared) so QStash can reach your machine.
NEXT_PUBLIC_APP_URL=http://localhost:3000
